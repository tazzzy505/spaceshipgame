[sub_resource type="Shader" id="Shader_4c57u"]
code = "shader_type spatial;
render_mode unshaded, blend_mix, depth_draw_never, cull_disabled;

uniform vec4 reticle_color : source_color = vec4(0.0, 1.0, 1.0, 0.85);

void fragment() {
	vec2 uv = UV - vec2(0.5);
	vec2 a = abs(uv);

	float outer = 0.35;
	float length = 0.12;
	float thickness = 0.012;

	// horizontal corner segments only near left/right edges
	float horiz =
		step(outer - length, a.x) *
		step(a.x, outer) *
		step(abs(a.y - outer), thickness);

	// vertical corner segments only near top/bottom edges
	float vert =
		step(outer - length, a.y) *
		step(a.y, outer) *
		step(abs(a.x - outer), thickness);

	float alpha = max(horiz, vert);

	ALBEDO = reticle_color.rgb;
	EMISSION = reticle_color.rgb * 3.0;
	ALPHA = alpha * reticle_color.a;
}"

